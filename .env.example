# ============================================================
# BOTTEU — Binance Spot Trading Bot
# Environment Configuration
# ============================================================
# Copy to .env and fill in real values. NEVER commit .env to git!

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-use-python-secrets-token-hex-32

# Database
DATABASE_URL=postgresql://botteu_user:strongpassword@localhost:5432/botteu_db

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Fernet Master Key (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# Keep this secret — it encrypts all Binance API keys stored in the database.
FERNET_KEY=your-base64-fernet-key-here

# Email (Flask-Mail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=BOTTEU <noreply@botteu.io>

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=https://yourdomain.com/telegram/webhook

# Stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# App URL
APP_URL=http://localhost:5000
